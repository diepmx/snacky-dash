* text=auto

# Unity YAML assets should stay text for diffs and merges.
*.anim text eol=lf
*.asset text eol=lf
*.controller text eol=lf
*.mat text eol=lf
*.meta text eol=lf
*.prefab text eol=lf
*.unity text eol=lf

# Code and project metadata.
*.asmdef text eol=lf
*.cginc text eol=lf
*.cs text eol=lf
*.json text eol=lf
*.shader text eol=lf
*.txt text eol=lf
*.xml text eol=lf

# Binary assets.
*.a binary
*.apk binary
*.dll binary
*.dylib binary
*.exe binary
*.fbx binary
*.gif binary
*.jar binary
*.jpg binary
*.jpeg binary
*.mp3 binary
*.ogg binary
*.png binary
*.psd binary
*.so binary
*.ttf binary
*.wav binary
