    - key: prefab_tuto_message_swipe_collect
      translations:
      - "<color=#446890>Swipe to Collect all the</color>\n<color=#FF6567>Berries!</color>"
      - "<color=#446890>Glisse pour collecter toutes les</color>\n<color=#FF6567>baies !</color>"
      - "<color=#446890>スワイプで集めよう</color>\n<color=#FF6567>全部のベリーを!</color>"
      - "<color=#446890>스와이프로 다 모아요</color>\n<color=#FF6567>베리!</color>"
      - "<color=#446890>Geser untuk mengumpulkan semua</color>\n<color=#FF6567>Beri!</color>"
      - "<color=#446890>Wische, um alle</color>\n<color=#FF6567>Beeren einzusammeln!</color>"
      - "<color=#446890>Desliza para recoger todas las</color>\n<color=#FF6567>bayas!</color>"
      - "<color=#446890>Scorri per raccogliere tutte le</color>\n<color=#FF6567>bacche!</color>"
      - "<color=#446890>Deslize para coletar todas as</color>\n<color=#FF6567>frutinhas!</color>"
      - "<color=#446890>Свайп, чтобы собрать все</color>\n<color=#FF6567>ягоды!</color>"
      - "<color=#446890>Kaydırarak tüm</color>\n<color=#FF6567>meyveleri topla!</color>"
    - key: prefab_tuto_message_deliver_them
      translations:
      - "<color=#446890>Deliver them</color>\n<color=#FF6567>quick!</color>"
      - "<color=#446890>Livre-les</color>\n<color=#FF6567>vite !</color>"
      - "<color=#446890>運ぼう</color>\n<color=#FF6567>急いで！</color>"
      - "<color=#446890>가져다 줘요</color>\n<color=#FF6567>어서!</color>"
      - "<color=#446890>Antar</color>\n<color=#FF6567>cepat!</color>"
      - "<color=#446890>Bring sie</color>\n<color=#FF6567>schnell!</color>"
      - "<color=#446890>Llévalas</color>\n<color=#FF6567>rápido!</color>"
      - "<color=#446890>Portale</color>\n<color=#FF6567>veloce!</color>"
      - "<color=#446890>Entregue-as</color>\n<color=#FF6567>rápido!</color>"
      - "<color=#446890>Доставь их</color>\n<color=#FF6567>скорее!</color>"
      - "<color=#446890>Götür onları</color>\n<color=#FF6567>çabuk!</color>"
    - key: prefab_tuto_message_collect_all
      translations:
      - "<color=#446890>COLLECT ALL FRUITS</color>\n<color=#FF6567>TO MAKE THEM REGROW</color>"
      - "<color=#446890>RAMASSE TOUS LES FRUITS</color>\n<color=#FF6567>POUR LES FAIRE REPOUSSER</color>"
      - "<color=#446890>すべてのフルーツを集めて</color>\n<color=#FF6567>もう一度実らせよう</color>"
      - "<color=#446890>모든 과일을 모아서</color>\n<color=#FF6567>다시 자라게 해요</color>"
      - "<color=#446890>KUMPULKAN SEMUA BUAH</color>\n<color=#FF6567>AGAR TUMBUH KEMBALI</color>"
      - "<color=#446890>SAMMLE ALLE FRÜCHTE,</color>\n<color=#FF6567>DAMIT SIE NACHWACHSEN</color>"
      - "<color=#446890>RECOGE TODAS LAS FRUTAS</color>\n<color=#FF6567>PARA QUE VUELVAN A CRECER</color>"
      - "<color=#446890>RACCOGLI TUTTI I FRUTTI</color>\n<color=#FF6567>PER FARLI RICRESCERE</color>"
      - "<color=#446890>COLETE TODAS AS FRUTAS</color>\n<color=#FF6567>PARA ELAS CRESCEREM DE NOVO</color>"
      - "<color=#446890>СОБЕРИ ВСЕ ФРУКТЫ,</color>\n<color=#FF6567>ЧТОБЫ ОНИ ВЫРОСЛИ СНОВА</color>"
      - "<color=#446890>TÜM MEYVELERİ TOPLA</color>\n<color=#FF6567>YENİDEN BÜYÜSÜNLER</color>"
    - key: prefab_tuto_message_be_careful
      translations:
      - "<color=#446890>BE CAREFUL NOT TO</color> <color=#FF6567>\nHIT YOURSELF</color>\n<color=#446890>WHEN THE SNAKE GETS LONG!</color> "
      - "<color=#446890>FAIS ATTENTION DE</color> <color=#FF6567>\nNE PAS TE PERCUTER,</color>\n<color=#446890>QUAND LE SERPENT S'ALLONGE !</color> "
      - "<color=#446890>気をつけよう</color> <color=#FF6567>\n自分にぶつからないように</color>\n<color=#446890>スネークが長くなったら!</color> "
      - "<color=#446890>조심해요</color> <color=#FF6567>\n자기와 부딪치지 않게</color>\n<color=#446890>뱀이 길어지면!</color> "
      - "<color=#446890>HATI-HATI</color> <color=#FF6567>\nJANGAN MENABRAK DIRI</color>\n<color=#446890>SAAT ULAR MEMANJANG!</color> "
      - "<color=#446890>PASS AUF,</color> <color=#FF6567>\nDICH NICHT SELBST ZU TREFFEN,</color>\n<color=#446890>WENN DIE SCHLANGE LANG WIRD!</color> "
      - "<color=#446890>TEN CUIDADO DE NO</color> <color=#FF6567>\nCHOCAR CONTIGO</color>\n<color=#446890>CUANDO LA SERPIENTE SE ALARGUE!</color> "
      - "<color=#446890>ATTENZIONE A NON</color> <color=#FF6567>\nSCONTRARTI,</color>\n<color=#446890>QUANDO IL SERPENTE SI ALLUNGA!</color> "
      - "<color=#446890>CUIDADO PARA NÃO</color> <color=#FF6567>\nSE BATER</color>\n<color=#446890>QUANDO A COBRA FICAR LONGA!</color> "
      - "<color=#446890>ОСТОРОЖНО, НЕ</color> <color=#FF6567>\nВРЕЖЬСЯ В СЕБЯ,</color>\n<color=#446890>КОГДА ЗМЕЯ ВЫТЯНЕТСЯ!</color> "
      - "<color=#446890>DİKKAT</color> <color=#FF6567>\nKENDİNE ÇARPMA</color>\n<color=#446890>YILAN UZADIĞINDA!</color> "
